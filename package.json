{
  "name": "smartlogix-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "web:dev": "npm run dev --workspace=web",
    "web:build": "npm run build --workspace=web",
    "backend:dev": "npm run start:dev --workspace=backend",
    "backend:build": "npm run build --workspace=backend",
    "build": "npm run web:build && npm run backend:build"
  },
  "workspaces": [
    "web",
    "backend",
    "mobile"
  ]
}
